<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clara_transaction_tree" model="ir.ui.view">
        <field name="name">clara.transaction.tree</field>
        <field name="model">clara.transaction</field>
        <field name="arch" type="xml">
            <tree string="Transactions" decoration-success="status=='approved'" decoration-danger="status=='declined'" decoration-warning="status=='pending'" decoration-muted="status=='reversed'">
                <field name="transaction_date"/>
                <field name="merchant_name"/>
                <field name="merchant_category"/>
                <field name="cardholder_name"/>
                <field name="card_last_four"/>
                <field name="amount"/>
                <field name="status"/>
                <field name="expense_id" widget="many2one_button"/>
                <field name="account_move_id" widget="many2one_button"/>
            </tree>
        </field>
    </record>

    <record id="view_clara_transaction_form" model="ir.ui.view">
        <field name="name">clara.transaction.form</field>
        <field name="model">clara.transaction</field>
        <field name="arch" type="xml">
            <form string="Transaction">
                <header>
                    <button name="action_create_expense" type="object" string="Create Expense" invisible="expense_id or status != 'approved'" class="btn btn-primary"/>
                    <button name="action_post_journal_entry" type="object" string="Post to Accounting" invisible="account_move_id or status != 'approved'" class="btn btn-secondary"/>
                    <field name="status" widget="statusbar" statusbar_visible="pending,approved,declined,reversed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_open_expense" icon="fa-money" invisible="not expense_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value">Expense</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_open_move" icon="fa-book" invisible="not account_move_id">
                            <div class="o_stat_info">
                                <span class="o_stat_value">Journal</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Transaction Details">
                            <field name="clara_uuid" readonly="1"/>
                            <field name="merchant_name"/>
                            <field name="merchant_category"/>
                            <field name="merchant_country"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="transaction_date"/>
                            <field name="posting_date"/>
                        </group>
                        <group string="Card Info">
                            <field name="card_uuid"/>
                            <field name="card_last_four"/>
                            <field name="cardholder_name"/>
                            <field name="cardholder_email"/>
                        </group>
                        <group string="Accounting">
                            <field name="expense_id" readonly="1"/>
                            <field name="account_move_id" readonly="1"/>
                        </group>
                        <group string="Sync Info">
                            <field name="sync_state"/>
                            <field name="last_sync_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Raw Payload" name="payload">
                            <field name="raw_payload" widget="text" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_clara_transaction_search" model="ir.ui.view">
        <field name="name">clara.transaction.search</field>
        <field name="model">clara.transaction</field>
        <field name="arch" type="xml">
            <search>
                <field name="merchant_name"/>
                <field name="cardholder_name"/>
                <field name="clara_uuid"/>
                <filter string="This Month" name="this_month" domain="[('transaction_date','&gt;=',(datetime.date.today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Pending Review" name="pending_review" domain="[('expense_id','=',False), ('status','=','approved')]"/>
                <filter string="Approved" name="status_approved" domain="[('status','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by':'status'}"/>
                    <filter string="Cardholder" name="group_by_cardholder" context="{'group_by':'cardholder_name'}"/>
                    <filter string="Merchant Category" name="group_by_category" context="{'group_by':'merchant_category'}"/>
                    <filter string="Card" name="group_by_card" context="{'group_by':'card_last_four'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_clara_transactions" model="ir.actions.act_window">
        <field name="name">All Transactions</field>
        <field name="res_model">clara.transaction</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_clara_transaction_search"/>
    </record>

    <record id="action_clara_transactions_pending" model="ir.actions.act_window">
        <field name="name">Pending Review</field>
        <field name="res_model">clara.transaction</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_pending_review': 1}</field>
    </record>
</odoo>
