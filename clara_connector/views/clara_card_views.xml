<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clara_card_tree" model="ir.ui.view">
        <field name="name">clara.card.tree</field>
        <field name="model">clara.card</field>
        <field name="arch" type="xml">
            <tree string="Cards">
                <field name="alias"/>
                <field name="last_four"/>
                <field name="cardholder_name"/>
                <field name="status" widget="badge" decoration-success="status=='active'" decoration-danger="status in ('cancelled','clara_blocked','closed')" decoration-warning="status in ('locked','master_locked')"/>
                <field name="credit_limit"/>
                <field name="threshold"/>
                <field name="periodicity"/>
            </tree>
        </field>
    </record>

    <record id="view_clara_card_kanban" model="ir.ui.view">
        <field name="name">clara.card.kanban</field>
        <field name="model">clara.card</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="alias"/>
                <field name="last_four"/>
                <field name="cardholder_name"/>
                <field name="status"/>
                <field name="credit_limit"/>
                <field name="threshold"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong t-esc="record.alias.value"/>
                                    <span class="text-muted ms-1">(*<t t-esc="record.last_four.value"/>)</span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body mt-2">
                                <div><i class="fa fa-user me-2"/> <t t-esc="record.cardholder_name.value"/></div>
                                <div><i class="fa fa-money me-2"/> Threshold: <field name="threshold"/> (<field name="periodicity"/>)</div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_clara_card_form" model="ir.ui.view">
        <field name="name">clara.card.form</field>
        <field name="model">clara.card</field>
        <field name="arch" type="xml">
            <form string="Card">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="alias" readonly="1"/></h1>
                    </div>
                    <notebook>
                        <page string="Card Details">
                            <group>
                                <group string="Status &amp; Type">
                                    <field name="last_four"/>
                                    <field name="card_type"/>
                                </group>
                                <group string="Limits">
                                    <field name="credit_limit"/>
                                    <field name="threshold"/>
                                    <field name="periodicity" readonly="1"/>
                                    <field name="currency_id" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Employee Information">
                            <group>
                                <field name="cardholder_name" readonly="1"/>
                                <field name="cardholder_uuid" readonly="1"/>
                                <field name="employee_id"/>
                            </group>
                        </page>
                        <page string="Technical" groups="base.group_no_one">
                            <group>
                                <field name="last_sync_date" readonly="1"/>
                                <field name="raw_payload" readonly="1" widget="ace" options="{'mode': 'python'}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_clara_cards" model="ir.actions.act_window">
        <field name="name">Cards</field>
        <field name="res_model">clara.card</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>
