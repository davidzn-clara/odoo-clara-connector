<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clara_sync_log_tree" model="ir.ui.view">
        <field name="name">clara.sync.log.tree</field>
        <field name="model">clara.sync.log</field>
        <field name="arch" type="xml">
            <tree string="Sync Logs" create="false" edit="false" decoration-success="state=='success'" decoration-danger="state=='failed'" decoration-warning="state=='partial'">
                <field name="name"/>
                <field name="sync_type"/>
                <field name="started_at"/>
                <field name="duration"/>
                <field name="records_fetched"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_clara_sync_log_form" model="ir.ui.view">
        <field name="name">clara.sync.log.form</field>
        <field name="model">clara.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log" create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sync_type"/>
                            <field name="triggered_by"/>
                            <field name="started_at"/>
                            <field name="finished_at"/>
                            <field name="duration"/>
                        </group>
                        <group string="Results">
                            <field name="records_fetched"/>
                            <field name="records_created"/>
                            <field name="records_updated"/>
                            <field name="records_skipped"/>
                            <field name="records_errored"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Error Log" invisible="not error_message">
                            <field name="error_message" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_clara_sync_logs" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">clara.sync.log</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
