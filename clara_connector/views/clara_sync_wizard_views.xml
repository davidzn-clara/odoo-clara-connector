<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_clara_sync_wizard_form" model="ir.ui.view">
        <field name="name">clara.sync.wizard.form</field>
        <field name="model">clara.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Run Clara Sync">
                <group>
                    <field name="sync_type" widget="radio"/>
                </group>
                <footer>
                    <button name="action_run_sync" type="object" string="Run Sync Now" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_clara_sync_wizard" model="ir.actions.act_window">
        <field name="name">Run Clara Sync</field>
        <field name="res_model">clara.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
