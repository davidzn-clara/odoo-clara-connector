<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_clara_sync_transactions" model="ir.cron">
            <field name="name">Clara: Sync Transactions</field>
            <field name="model_id" ref="model_clara_transaction"/>
            <field name="state">code</field>
            <field name="code">model._run_sync(triggered_by='cron')</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_clara_sync_cards" model="ir.cron">
            <field name="name">Clara: Sync Cards</field>
            <field name="model_id" ref="model_clara_card"/>
            <field name="state">code</field>
            <field name="code">model._run_card_sync(triggered_by='cron')</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
